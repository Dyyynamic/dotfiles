// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "buffer_font_family": "JetBrainsMono Nerd Font Propo",
  "ensure_final_newline_on_save": false,
  "format_on_save": "off",
  "edit_predictions": {
    "mode": "eager",
    "provider": "zed",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Soft Charmed Icons",
    "dark": "Soft Charmed Icons",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16.0,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "dark",
    "light": "Matugen Light",
    "dark": "Matugen Dark",
  },
  "wrap_guides": [80],
  "auto_install_extensions": {
    "html": true,
    "git-firefly": true,
    "toml": true,
    "scss": true,
    "make": true,
    "lua": true,
    "svelte": true,
    "latex": true,
    "ini": true,
    "charmed-icons": true,
    "glsl": true,
    "qml": true,
  },
  "lsp": {
    "qmljs": {
      "binary": {
        "arguments": ["-E"],
      },
    },
  },
}
